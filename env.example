# Brevo transactional email (contact forms)
BREVO_API_KEY=
# Verified sender address in Brevo
BREVO_SENDER_EMAIL=
# Inbox that receives contact form submissions
BREVO_RECIPIENT_EMAIL=
# Optional sender display name (defaults to "PETROA")
BREVO_SENDER_NAME=

# Cloudflare Turnstile captcha (contact forms)
# Create a widget at https://dash.cloudflare.com -> Turnstile to get both keys.
# If unset, the captcha is skipped on both client and server (local dev fallback).
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Canonical site URL (used for metadata/SEO)
NEXT_PUBLIC_SITE_URL=
